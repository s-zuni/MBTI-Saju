{
    "version": 2,
    "functions": {
        "api/**/*.ts": {
            "maxDuration": 60
        }
    },
    "rewrites": [
        { "source": "/api/confirm-payment", "destination": "/api/payment?action=confirm" },
        { "source": "/api/cancel-payment", "destination": "/api/payment?action=cancel" },
        { "source": "/api/naming", "destination": "/api/analysis-special?type=naming" },
        { "source": "/api/job", "destination": "/api/analysis-special?type=job" },
        { "source": "/api/trip", "destination": "/api/analysis-special?type=trip" },
        { "source": "/api/cherry", "destination": "/api/analysis-special?type=cherry" },
        { "source": "/api/fortune", "destination": "/api/analysis-special?type=fortune" },
        { "source": "/api/analyze", "destination": "/api/analysis-main?part=core" },
        { "source": "/api/analyze_fortune", "destination": "/api/analysis-main?part=fortune" },
        { "source": "/api/analyze_strategy", "destination": "/api/analysis-main?part=strategy" },
        { "source": "/api/analyze_full", "destination": "/api/analysis-main?part=full" },
        {
            "source": "/backend/:path*",
            "destination": "https://tffvsyarxfujmvbqlutr.supabase.co/:path*"
        },
        {
            "source": "/((?!backend|api|static|favicon.ico|logo.*|manifest.json|robots.txt).*)",
            "destination": "/index.html"
        }
    ]
}