    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.30.2",
    "react-scripts": "5.0.1",
    "zod": "^4.3.6"
  },
  "scripts": {
    "start": "craco start",
    "build": "ait build && node -e \"const fs=require('fs'); const path=require('path'); const s='build/web'; const d='build'; if(fs.existsSync(s)){fs.readdirSync(s).forEach(f=>{const sp=path.join(s,f); const dp=path.join(d,f); if(fs.statSync(sp).isDirectory()){fs.cpSync(sp,dp,{recursive:true})}else{fs.copyFileSync(sp,dp)}})}\"",
    "test": "craco test",
    "eject": "react-scripts eject",
    "dev": "granite dev",
    "deploy": "ait deploy"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.5"
  }
}
