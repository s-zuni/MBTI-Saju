        const sajuContext = buildRichSajuContext(userSaju);
        const userQuery = `?대쫫: ${name}, MBTI: ${mbti}, ?앸뀈?붿씪?? ${birthInfo}, ?좏삎: ${reportType}, ?붿껌: ${specialRequest}\n${sajuContext}`;

